window.createUI();

async function updateUI() {
  try {
    const res = await fetch("http://localhost:3000/api/sensors");
    const data = await res.json();

    if (data.humidity !== undefined) {
      const h = Math.max(0, Math.min(100, Number(data.humidity)));
      document.getElementById("gaugeHum").style.setProperty("--v", h);
      document.getElementById("valHum").textContent = h + "%";
      document.getElementById("stateHum").textContent = "Reçu";
    }

    if (data.temperature !== undefined) {
      const t = Number(data.temperature);
      const percent = Math.max(0, Math.min(100, (t / 50) * 100));
      document.getElementById("gaugeTemp").style.setProperty("--v", percent);
      document.getElementById("valTemp").textContent = t + "°C";
      document.getElementById("stateTemp").textContent = "Reçu";
    }

    if (data.battery !== undefined) {
      const b = Math.max(0, Math.min(100, Number(data.battery)));
      document.getElementById("gaugeBatt").style.setProperty("--v", b);
      document.getElementById("valBatt").textContent = b + "%";
      document.getElementById("stateBatt").textContent = "Reçu";
    }

    if (data.flow !== undefined) {
      const f = Math.max(0, Math.min(100, Number(data.flow)));
      document.getElementById("gaugeFlow").style.setProperty("--v", f);
      document.getElementById("valFlow").textContent = f + " L/h";
      document.getElementById("stateFlow").textContent = "Reçu";
    }

    if (data.pourcentage !== undefined) {
      const p = Math.max(0, Math.min(100, Number(data.pourcentage)));
      document.getElementById("gaugePourc").style.setProperty("--v", p);
      document.getElementById("valPourc").textContent = p + "%";
      document.getElementById("statePourc").textContent = "Reçu";
    }

  } catch (err) {
    console.error("Erreur récupération données :", err);
  }
}

updateUI();
setInterval(updateUI, 2000);
